{
  "name": "og-pilot-js",
  "version": "0.4.15",
  "description": "JavaScript/TypeScript client for the OG Pilot Open Graph image generator.",
  "license": "MIT",
  "author": "Sunergos IT LLC",
  "homepage": "https://ogpilot.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunergos-ro/og-pilot-js.git"
  },
  "bugs": {
    "url": "https://github.com/sunergos-ro/og-pilot-js/issues"
  },
  "keywords": [
    "og-pilot",
    "open-graph",
    "og-image",
    "social-media",
    "meta-tags"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "npm run build && node --test tests/strip-query-parameters.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
